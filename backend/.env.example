# =============================================
# VARIABILI D'AMBIENTE - Railway
# =============================================
# Copia queste variabili in Railway > Settings > Variables

# --- Connessione Neon Database ---
# Copia la "Connection string" da Neon Console > Dashboard > Connection Details
# Formato: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# --- Sicurezza JWT ---
# Metti una stringa lunga e casuale (es. genera con: openssl rand -hex 32)
JWT_SECRET=cambia_questa_stringa_con_qualcosa_di_sicuro_e_lungo

# --- Password Admin ---
# Password per l'utente admin (default: admin123)
ADMIN_PASSWORD=admin123

# --- Porta (Railway la imposta automaticamente, non serve cambiarla) ---
# PORT=3000
