# ========================================
# ESEMPI CONFIGURAZIONE .env
# ========================================
# Copia uno di questi esempi nel tuo .env
# e sostituisci con le TUE credenziali
# ========================================

# --------------------------------------
# OPZIONE 1: DATABASE LOCALE (Docker/PostgreSQL)
# --------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=admin123
DB_NAME=concessionario_db
DB_SSL=false

JWT_SECRET=your_secret_key_here_change_in_production_12345
JWT_EXPIRES_IN=24h
PORT=3000

# --------------------------------------
# OPZIONE 2: NEON.TECH (Cloud - Consigliato)
# --------------------------------------
# Connection string example:
# postgres://neondb_owner:AbCdEf123@ep-cool-meadow-123456.eu-central-1.aws.neon.tech/concessionario_db

DB_HOST=ep-cool-meadow-123456.eu-central-1.aws.neon.tech
DB_PORT=5432
DB_USER=neondb_owner
DB_PASSWORD=AbCdEf123GuHijK456
DB_NAME=concessionario_db
DB_SSL=true

JWT_SECRET=TuaChiaveSegretaMoltoLunga_12345678_Produzione
JWT_EXPIRES_IN=24h
PORT=3000

# --------------------------------------
# OPZIONE 3: SUPABASE (Cloud)
# --------------------------------------
# Connection string example (Connection Pooling):
# postgres://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

DB_HOST=aws-0-eu-west-1.pooler.supabase.com
DB_PORT=6543
DB_USER=postgres.xxxxxxxxxxxx
DB_PASSWORD=your_supabase_password
DB_NAME=postgres
DB_SSL=true

JWT_SECRET=TuaChiaveSegretaMoltoLunga_12345678_Produzione
JWT_EXPIRES_IN=24h
PORT=3000

# --------------------------------------
# OPZIONE 4: RENDER (Cloud)
# --------------------------------------
# External Database URL example:
# postgres://concessionario_user:abc123def456@dpg-xxxxxxxxx.frankfurt-postgres.render.com/concessionario_db

DB_HOST=dpg-xxxxxxxxx.frankfurt-postgres.render.com
DB_PORT=5432
DB_USER=concessionario_user
DB_PASSWORD=abc123def456ghi789
DB_NAME=concessionario_db
DB_SSL=true

JWT_SECRET=TuaChiaveSegretaMoltoLunga_12345678_Produzione
JWT_EXPIRES_IN=24h
PORT=3000

# --------------------------------------
# OPZIONE 5: ELEPHANTSQL (Cloud - Deprecated)
# --------------------------------------
# URL example:
# postgres://username:password@jelani.db.elephantsql.com/username

DB_HOST=jelani.db.elephantsql.com
DB_PORT=5432
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=your_username
DB_SSL=true

JWT_SECRET=TuaChiaveSegretaMoltoLunga_12345678_Produzione
JWT_EXPIRES_IN=24h
PORT=3000

# ========================================
# IMPORTANTE:
# ========================================
# 1. NON committare il file .env su Git!
# 2. Usa password forti in produzione
# 3. Cambia JWT_SECRET con valore casuale lungo
# 4. Per DB cloud, imposta sempre DB_SSL=true
# 5. Alcuni provider usano nomi database diversi (es. Supabase usa 'postgres')
# ========================================
